{
  "name": "isso",
  "author": "Martin Zimmermann",
  "description": "A lightweight, self-hosted commenting service",
  "license": "MIT",
  "repository": "github:jelmer/isso-rs",
  "scripts": {
    "test": "jest --config static/js/jest.config.js static/js/tests/",
    "test-unit": "jest --config static/js/jest-unit.config.js static/js/tests/unit/",
    "test-integration": "jest --runInBand --config static/js/jest-integration.config.js static/js/tests/integration/",
    "test-screenshots": "jest --runInBand --config static/js/jest-integration.config.js static/js/tests/screenshots/",
    "build-dev": "webpack --config static/js/webpack.config.js --config-name dev",
    "watch-dev": "webpack --config static/js/webpack.config.js --config-name dev --watch",
    "build-prod": "webpack --config static/js/webpack.config.js --merge --config-name dev --config-name prod"
  },
  "devDependencies": {
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "optionalDependencies": {
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0"
  }
}
